# ============================================
# SaaS 小程序项目 Git 忽略规则
# ============================================

# ========== Node.js 依赖 ==========
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ========== 构建输出 ==========
dist/
build/
out/

# ========== Java/Maven ==========
target/
*.class
*.jar
*.war
*.ear
.mvn/
mvnw
mvnw.cmd

# ========== IDE/编辑器 ==========
.vscode/
.idea/
*.iml
*.iws
*.ipr
.project
.settings/
.classpath

# ========== 操作系统文件 ==========
.DS_Store
Thumbs.db
desktop.ini
*~

# ========== 环境变量（可能包含敏感信息）==========
.env
.env.local
.env.*.local
.env.production

# ========== AI 工具缓存 ==========
.lingma/
.workbuddy/
.ai/
.cursor/
.claude/

# ========== 临时文件 ==========
*.tmp
*.temp
*.log
*.swo
*.swp
*~
.cache/

# ========== 数据库临时SQL脚本（项目根目录）==========
cart_batch*.sql
temp_*.sql
*.sql.tmp

# ========== 备份目录 ==========
管理后台-backup/
*-backup/

# ========== 编译产物 ==========
*.min.js
*.min.css

# ========== 测试覆盖率 ==========
coverage/
.nyc_output/

# ========== 本地配置 ==========
*.local
*.local.json
